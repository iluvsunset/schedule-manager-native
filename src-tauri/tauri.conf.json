{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Schedule Manager",
  "version": "0.1.8",
  "identifier": "com.sunset.schedule",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Schedule Manager",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "infoPlist": "Info.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyREE1Q0M4NDI0RkY2RjAKUldUdzlrOUN5RnphUW0yQy9SZ3hNbUlwOVV3dUhYUlRINkJWOEZlSlBhQnBVOU5hbWEwV1N4bXgK",
      "endpoints": [
        "https://schedule-iluvsunset.vercel.app/updater.json"
      ]
    }
  }
}
